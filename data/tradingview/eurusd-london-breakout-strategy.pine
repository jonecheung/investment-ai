//@version=5
// PASTE INSTRUCTION: Select ALL default Pine Editor code, delete it, then paste ONLY this file.
strategy(
     "EURUSD London Breakout Strategy",
     overlay=true,
     pyramiding=0,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_order,
     commission_value=5.0,
     slippage=2,
     calc_on_order_fills=true,
     process_orders_on_close=true)

// Route A — FX London Breakout (community standard for EURUSD).
// Asian range session → London window breakout of Asian high/low.

sessionGroup = "Sessions"
asianSession = input.session("0000-0800", "Asian Range Session", group=sessionGroup)
londonSession = input.session("0800-1600", "London Trade Window", group=sessionGroup)
sessionTimezone = input.string("Etc/UTC", "Session Timezone", group=sessionGroup)
closeAtLondonEnd = input.bool(true, "Close At London Session End", group=sessionGroup)

rangeGroup = "Range Filters"
atrLength = input.int(14, "ATR Length", minval=1, group=rangeGroup)
minRangeAtr = input.float(0.20, "Min Asian Range (ATR multiple)", minval=0.0, step=0.05, group=rangeGroup)
maxRangeAtr = input.float(2.50, "Max Asian Range (ATR multiple, 0=off)", minval=0.0, step=0.1, group=rangeGroup)

tradeGroup = "Trade Rules"
tradeMode = input.string("Long and Short", "Trade Mode", options=["Long Only", "Long and Short"], group=tradeGroup)
allowLong = tradeMode == "Long Only" or tradeMode == "Long and Short"
allowShort = tradeMode == "Long and Short"
rewardRiskTarget = input.float(1.5, "Reward Risk Target", minval=0.5, step=0.1, group=tradeGroup)
useRangeTarget = input.bool(false, "Target = Range Multiple (overrides RR)", group=tradeGroup)
rangeTargetMultiple = input.float(1.5, "Range Target Multiple", minval=0.5, step=0.1, group=tradeGroup)
stopMode = input.string(
     "Asian Range Opposite Side",
     "Stop Anchor",
     options=["Asian Range Opposite Side", "ATR Multiple"],
     group=tradeGroup)
atrStopMultiple = input.float(1.5, "ATR Stop Multiple", minval=0.5, step=0.1, group=tradeGroup)
oneTradePerDay = input.bool(true, "One Trade Per Day", group=tradeGroup)
entryOnNextBar = input.bool(true, "Enter On Next Bar Open", group=tradeGroup)

filterGroup = "Quality Filters"
useTrendFilter = input.bool(true, "Use EMA Trend Filter", group=filterGroup)
trendEmaLength = input.int(200, "Trend EMA Length", minval=1, group=filterGroup)

riskGroup = "Position Sizing"
useRiskSizing = input.bool(true, "Size By Risk % Of Equity", group=riskGroup)
riskPct = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, group=riskGroup)
fixedQty = input.float(1000.0, "Fixed Quantity (when risk sizing off)", minval=1.0, step=100.0, group=riskGroup)

atr = ta.atr(atrLength)
trendEma = ta.ema(close, trendEmaLength)

inAsian = not na(time(timeframe.period, asianSession, sessionTimezone))
inLondon = not na(time(timeframe.period, londonSession, sessionTimezone))
asianStart = inAsian and not inAsian[1]
asianEnd = not inAsian and inAsian[1]
londonEnd = not inLondon and inLondon[1]

var float asianHigh = na
var float asianLow = na
var float lockedAsianHigh = na
var float lockedAsianLow = na
var bool rangeReady = false
var bool tradedToday = false
var bool pendingLong = false
var bool pendingShort = false
var float pendingLongStop = na
var float pendingShortStop = na

if asianStart
    asianHigh := high
    asianLow := low
    lockedAsianHigh := na
    lockedAsianLow := na
    rangeReady := false
    tradedToday := false
    pendingLong := false
    pendingShort := false
else if inAsian
    asianHigh := na(asianHigh) ? high : math.max(asianHigh, high)
    asianLow := na(asianLow) ? low : math.min(asianLow, low)
else if not inAsian and not inLondon
    pendingLong := false
    pendingShort := false

if asianEnd
    lockedAsianHigh := asianHigh
    lockedAsianLow := asianLow
    rangeReady := not na(lockedAsianHigh) and not na(lockedAsianLow) and lockedAsianHigh > lockedAsianLow

asianRange = rangeReady ? lockedAsianHigh - lockedAsianLow : na
minRangeOk = not rangeReady or minRangeAtr <= 0 or asianRange >= atr * minRangeAtr
maxRangeOk = not rangeReady or maxRangeAtr <= 0 or asianRange <= atr * maxRangeAtr
rangeOk = rangeReady and minRangeOk and maxRangeOk

longTrendOk = not useTrendFilter or close > trendEma
shortTrendOk = not useTrendFilter or close < trendEma
canEnter = not oneTradePerDay or not tradedToday

longBreak = rangeOk and inLondon and allowLong and longTrendOk and canEnter and strategy.position_size == 0 and ta.crossover(close, lockedAsianHigh)
shortBreak = rangeOk and inLondon and allowShort and shortTrendOk and canEnter and strategy.position_size == 0 and ta.crossunder(close, lockedAsianLow)

resolveLongStop(entryPrice) =>
    stopMode == "Asian Range Opposite Side" ? lockedAsianLow : entryPrice - atrStopMultiple * atr

resolveShortStop(entryPrice) =>
    stopMode == "Asian Range Opposite Side" ? lockedAsianHigh : entryPrice + atrStopMultiple * atr

calcTarget(isLong, entryPrice, stopPrice) =>
    risk = math.abs(entryPrice - stopPrice)
    if useRangeTarget and rangeOk
        isLong ? entryPrice + asianRange * rangeTargetMultiple : entryPrice - asianRange * rangeTargetMultiple
    else
        isLong ? entryPrice + rewardRiskTarget * risk : entryPrice - rewardRiskTarget * risk

if longBreak
    pendingLong := true
    pendingLongStop := resolveLongStop(close)
    pendingShort := false
else if shortBreak
    pendingShort := true
    pendingShortStop := resolveShortStop(close)
    pendingLong := false

longEntryNow = inLondon and strategy.position_size == 0 and canEnter and (entryOnNextBar ? pendingLong[1] : pendingLong)
shortEntryNow = inLondon and strategy.position_size == 0 and canEnter and (entryOnNextBar ? pendingShort[1] : pendingShort)

calcQty(entryPrice, stopPrice) =>
    riskPerUnit = math.abs(entryPrice - stopPrice)
    if not useRiskSizing
        fixedQty
    else if riskPerUnit <= syminfo.mintick
        fixedQty
    else
        riskCash = strategy.equity * riskPct / 100.0
        pointValue = nz(syminfo.pointvalue, 1.0)
        qty = riskCash / (riskPerUnit * pointValue)
        math.max(qty, 1.0)

if longEntryNow
    entry = entryOnNextBar ? open : close
    stop = entryOnNextBar ? pendingLongStop[1] : pendingLongStop
    target = calcTarget(true, entry, stop)
    risk = entry - stop
    if risk > syminfo.mintick and target > entry
        qty = calcQty(entry, stop)
        strategy.entry("London Long", strategy.long, qty=qty)
        strategy.exit("London Long Exit", "London Long", stop=stop, limit=target)
        tradedToday := true
    pendingLong := false

if shortEntryNow
    entry = entryOnNextBar ? open : close
    stop = entryOnNextBar ? pendingShortStop[1] : pendingShortStop
    target = calcTarget(false, entry, stop)
    risk = stop - entry
    if risk > syminfo.mintick and target < entry
        qty = calcQty(entry, stop)
        strategy.entry("London Short", strategy.short, qty=qty)
        strategy.exit("London Short Exit", "London Short", stop=stop, limit=target)
        tradedToday := true
    pendingShort := false

if closeAtLondonEnd and londonEnd and strategy.position_size != 0
    strategy.close_all("London End")

plot(rangeReady ? lockedAsianHigh : na, "Asian High", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(rangeReady ? lockedAsianLow : na, "Asian Low", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(useTrendFilter ? trendEma : na, "Trend EMA", color=color.new(color.blue, 30))
plotshape(longEntryNow, "Long Entry", shape.triangleup, location.belowbar, color=color.green, size=size.small, text="L")
plotshape(shortEntryNow, "Short Entry", shape.triangledown, location.abovebar, color=color.red, size=size.small, text="S")
bgcolor(inAsian ? color.new(color.gray, 90) : inLondon ? color.new(color.teal, 92) : na, title="Session")
bgcolor(rangeReady and not rangeOk ? color.new(color.orange, 88) : na, title="Range Skip")
