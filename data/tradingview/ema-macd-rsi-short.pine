//@version=5
indicator("EMA MACD RSI Short Screener", overlay=true)

// Pine Screener-compatible bearish momentum setup for medium-term daily charts (1-3 months).
// Screener can only display/filter plot() outputs, so all Notion-facing values are plots.
emaLength = input.int(200, "Trend EMA Length", minval=1)
macdFastLength = input.int(12, "MACD Fast Length", minval=1)
macdSlowLength = input.int(26, "MACD Slow Length", minval=1)
macdSignalLength = input.int(9, "MACD Signal Length", minval=1)
rsiLength = input.int(14, "RSI Length", minval=1)
rsiMin = input.float(30.0, "RSI Minimum", minval=0.0, maxval=100.0, step=0.5)
rsiMax = input.float(50.0, "RSI Maximum", minval=0.0, maxval=100.0, step=0.5)
atrLength = input.int(14, "ATR Length", minval=1)
swingLookback = input.int(20, "Swing High Lookback", minval=2)
stopAtrBuffer = input.float(0.5, "Stop ATR Buffer Above Swing High", minval=0.0, step=0.1)
fallbackStopAtrMultiplier = input.float(2.5, "Fallback Stop ATR Multiplier", minval=0.1, step=0.1)
rewardRiskTarget = input.float(2.5, "Reward Risk Target", minval=0.1, step=0.1)
requireMacdBelowZero = input.bool(true, "Require MACD Below Zero")
requireMacdBearishCross = input.bool(false, "Require Fresh MACD Bearish Cross")

ema = ta.ema(close, emaLength)
[macdLine, signalLine, macdHist] = ta.macd(close, macdFastLength, macdSlowLength, macdSignalLength)
rsi = ta.rsi(close, rsiLength)
atr = ta.atr(atrLength)

trendOk = close < ema
macdBearish = macdLine < signalLine and (not requireMacdBelowZero or macdLine < 0)
macdBearishCross = ta.crossunder(macdLine, signalLine)
macdOk = macdBearish and (not requireMacdBearishCross or macdBearishCross)
rsiOk = rsi >= rsiMin and rsi <= rsiMax

// Use completed prior bars for the stop reference so the current candle can trigger the setup.
swingHigh = ta.highest(high[1], swingLookback)
swingStop = swingHigh + stopAtrBuffer * atr
fallbackStop = close + fallbackStopAtrMultiplier * atr
candidateStop = not na(swingStop) and swingStop > close ? swingStop : fallbackStop
risk = candidateStop - close

setupActive = trendOk and macdOk and rsiOk and risk > 0
newShortSetup = setupActive and not setupActive[1]

entryPrice = setupActive ? close : na
stopPrice = setupActive ? candidateStop : na
targetPrice = setupActive ? close - rewardRiskTarget * risk : na
rewardRiskRatio = setupActive ? rewardRiskTarget : na

// Keep these first: Pine Screener automatically adds the first ten plots as columns/filters.
plot(setupActive ? 1 : 0, "Setup Active", color=color.new(color.red, 0))
plot(newShortSetup ? 1 : 0, "New Setup", color=color.new(color.maroon, 0))
plot(entryPrice, "Entry Price", color=color.new(color.blue, 0), linewidth=2)
plot(stopPrice, "Stop Price", color=color.new(color.red, 0), linewidth=2)
plot(targetPrice, "Target Price", color=color.new(color.green, 0), linewidth=2)
plot(rewardRiskRatio, "Reward Risk Ratio", color=color.new(color.purple, 0))
plot(trendOk ? 1 : 0, "Close Below EMA", color=color.new(color.orange, 0))
plot(macdOk ? 1 : 0, "MACD Bearish", color=color.new(color.teal, 0))
plot(rsiOk ? 1 : 0, "RSI Weak Zone", color=color.new(color.gray, 0))
plot(rsi, "RSI", color=color.new(color.purple, 50))

plot(ema, "Trend EMA", color=color.orange)
plot(swingHigh, "Swing High", color=color.new(color.red, 50))
plot(macdHist, "MACD Histogram", color=macdHist < 0 ? color.red : color.green)

plotshape(newShortSetup, "New Short Setup", shape.triangledown, location.abovebar, color=color.red, size=size.small, text="Short")
alertcondition(newShortSetup, "New Short Setup", "New EMA MACD RSI short setup generated.")
