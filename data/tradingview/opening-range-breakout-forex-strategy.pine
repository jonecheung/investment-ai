//@version=5
strategy(
     "Opening Range Breakout Forex Strategy",
     overlay=true,
     pyramiding=0,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_order,
     commission_value=5.0,
     slippage=2,
     calc_on_order_fills=true,
     process_orders_on_close=true)

// Backtestable ORB for FX majors on 15m/30m charts.
// v3 (Route B): retest entry, max OR width skip, failed-breakout reversal.

presetGroup = "Strategy Preset"
strategyPreset = input.string(
     "30min Long (1:1 RR)",
     "Preset",
     options=["30min Long (1:1 RR)", "15min Long+Short (1:2 RR)"],
     group=presetGroup)
usePresetParams = input.bool(true, "Use Preset OR Minutes / RR / Direction", group=presetGroup)

sessionGroup = "Session"
tradingSession = input.session("0800-1200", "Trading Session", group=sessionGroup)
sessionTimezone = input.string("Etc/UTC", "Session Timezone", group=sessionGroup)
closeAtSessionEnd = input.bool(false, "Close Open Position At Session End", group=sessionGroup)

orGroup = "Opening Range"
orMinutesInput = input.int(30, "Opening Range Minutes", minval=5, maxval=120, group=orGroup)
orMinutes = usePresetParams ? (strategyPreset == "30min Long (1:1 RR)" ? 30 : 15) : orMinutesInput
atrLength = input.int(14, "ATR Length (filters)", minval=1, group=orGroup)
minOrAtrMultiple = input.float(0.25, "Min OR Width (ATR multiple)", minval=0.0, step=0.05, group=orGroup)
maxOrAtrMultiple = input.float(2.5, "Max OR Width (ATR multiple, 0=off)", minval=0.0, step=0.1, group=orGroup)

tradeGroup = "Trade Rules"
tradeModeInput = input.string("Long Only", "Trade Mode", options=["Long Only", "Long and Short"], group=tradeGroup)
tradeMode = usePresetParams ? (strategyPreset == "30min Long (1:1 RR)" ? "Long Only" : "Long and Short") : tradeModeInput
allowLong = tradeMode == "Long Only" or tradeMode == "Long and Short"
allowShort = tradeMode == "Long and Short"
rewardRiskInput = input.float(1.0, "Reward Risk Target", minval=0.1, step=0.05, group=tradeGroup)
rewardRiskTarget = usePresetParams ? (strategyPreset == "30min Long (1:1 RR)" ? 1.0 : 2.05) : rewardRiskInput
requireCloseBreakout = input.bool(true, "Require Close Beyond OR (not wick only)", group=tradeGroup)
oneTradePerSession = input.bool(true, "One Trade Per Session", group=tradeGroup)
stopMode = input.string(
     "OR Opposite Side",
     "Stop Anchor",
     options=["OR Opposite Side", "Breakout Bar Extreme"],
     group=tradeGroup)
entryOnNextBar = input.bool(true, "Enter On Next Bar Open (reduces look-ahead)", group=tradeGroup)

routeBGroup = "Route B — Retest & Reversal"
entryStyle = input.string(
     "Retest Only",
     "Entry Style",
     options=["Immediate Breakout", "Retest Only", "Both"],
     group=routeBGroup)
retestLevel = input.string("OR Boundary", "Retest Level", options=["OR Boundary", "OR Midpoint"], group=routeBGroup)
enableReversalEntries = input.bool(true, "Failed Breakout Reversal", group=routeBGroup)
requireRetestConfirmBar = input.bool(true, "Retest Confirm: Directional Close", group=routeBGroup)

filterGroup = "Quality Filters"
useTrendFilter = input.bool(true, "Use EMA Trend Filter", group=filterGroup)
trendEmaLength = input.int(200, "Trend EMA Length", minval=1, group=filterGroup)

riskGroup = "Position Sizing"
useRiskSizing = input.bool(true, "Size By Risk % Of Equity", group=riskGroup)
riskPct = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, group=riskGroup)
fixedQty = input.float(1000.0, "Fixed Quantity (when risk sizing off)", minval=1.0, step=100.0, group=riskGroup)

atr = ta.atr(atrLength)
trendEma = ta.ema(close, trendEmaLength)

inSession = not na(time(timeframe.period, tradingSession, sessionTimezone))
newSession = inSession and not inSession[1]
sessionEnded = not inSession and inSession[1]

var int orStartMs = na
var float orHigh = na
var float orLow = na
var bool orBuilding = false
var float lockedOrHigh = na
var float lockedOrLow = na
var bool tradedThisSession = false
var bool pendingLong = false
var bool pendingShort = false
var float pendingLongStop = na
var float pendingShortStop = na
var bool brokeAboveOr = false
var bool brokeBelowOr = false
var bool retestArmedLong = false
var bool retestArmedShort = false

if newSession
    orStartMs := time
    orHigh := high
    orLow := low
    orBuilding := true
    lockedOrHigh := na
    lockedOrLow := na
    tradedThisSession := false
    brokeAboveOr := false
    brokeBelowOr := false
    retestArmedLong := false
    retestArmedShort := false
    pendingLong := false
    pendingShort := false
else if inSession and orBuilding
    orHigh := math.max(orHigh, high)
    orLow := math.min(orLow, low)
    if (time - orStartMs) >= orMinutes * 60 * 1000
        orBuilding := false
        lockedOrHigh := orHigh
        lockedOrLow := orLow
else if not inSession
    orBuilding := false
    orHigh := na
    orLow := na
    lockedOrHigh := na
    lockedOrLow := na
    pendingLong := false
    pendingShort := false
    brokeAboveOr := false
    brokeBelowOr := false
    retestArmedLong := false
    retestArmedShort := false

orReady = inSession and not orBuilding and not na(lockedOrHigh) and not na(lockedOrLow)
orMid = (lockedOrHigh + lockedOrLow) / 2.0
orWidth = lockedOrHigh - lockedOrLow
minWidthOk = minOrAtrMultiple <= 0 or orWidth >= atr * minOrAtrMultiple
maxWidthOk = maxOrAtrMultiple <= 0 or orWidth <= atr * maxOrAtrMultiple
orWidthOk = orReady and minWidthOk and maxWidthOk

longLevel = retestLevel == "OR Midpoint" ? orMid : lockedOrHigh
shortLevel = retestLevel == "OR Midpoint" ? orMid : lockedOrLow

longTrendOk = not useTrendFilter or close > trendEma
shortTrendOk = not useTrendFilter or close < trendEma
canEnter = not oneTradePerSession or not tradedThisSession

if orWidthOk
    if close > lockedOrHigh
        brokeAboveOr := true
    if close < lockedOrLow
        brokeBelowOr := true
    if brokeAboveOr and low <= longLevel
        retestArmedLong := true
    if brokeBelowOr and high >= shortLevel
        retestArmedShort := true

longBreakRaw = orWidthOk and close > lockedOrHigh and (not requireCloseBreakout or close[1] <= lockedOrHigh)
shortBreakRaw = orWidthOk and close < lockedOrLow and (not requireCloseBreakout or close[1] >= lockedOrLow)

longRetestRaw = orWidthOk and retestArmedLong and close > longLevel and (not requireRetestConfirmBar or close > open)
shortRetestRaw = orWidthOk and retestArmedShort and close < shortLevel and (not requireRetestConfirmBar or close < open)

failedBullBreak = orWidthOk and brokeAboveOr and ta.crossunder(close, lockedOrHigh) and close >= lockedOrLow
failedBearBreak = orWidthOk and brokeBelowOr and ta.crossover(close, lockedOrLow) and close <= lockedOrHigh

allowImmediate = entryStyle == "Immediate Breakout" or entryStyle == "Both"
allowRetest = entryStyle == "Retest Only" or entryStyle == "Both"

immediateLong = allowImmediate and longBreakRaw and longTrendOk and canEnter
immediateShort = allowImmediate and shortBreakRaw and shortTrendOk and canEnter
retestLong = allowRetest and longRetestRaw and longTrendOk and canEnter
retestShort = allowRetest and shortRetestRaw and shortTrendOk and canEnter
reversalLong = enableReversalEntries and failedBearBreak and longTrendOk and canEnter
reversalShort = enableReversalEntries and failedBullBreak and shortTrendOk and canEnter

longSignal = allowLong and (immediateLong or retestLong or reversalLong)
shortSignal = allowShort and (immediateShort or retestShort or reversalShort)

longStopOnSignal = stopMode == "OR Opposite Side" ? lockedOrLow : low
shortStopOnSignal = stopMode == "OR Opposite Side" ? lockedOrHigh : high
reversalLongStop = stopMode == "OR Opposite Side" ? lockedOrLow : high
reversalShortStop = stopMode == "OR Opposite Side" ? lockedOrHigh : low

resolveLongStop(isReversal) =>
    isReversal ? reversalLongStop : longStopOnSignal

resolveShortStop(isReversal) =>
    isReversal ? reversalShortStop : shortStopOnSignal

isReversalLong = reversalLong and not immediateLong and not retestLong
isReversalShort = reversalShort and not immediateShort and not retestShort

if strategy.position_size == 0 and canEnter
    if longSignal and not shortSignal
        pendingLong := true
        pendingLongStop := resolveLongStop(isReversalLong)
        pendingShort := false
    else if shortSignal and not longSignal
        pendingShort := true
        pendingShortStop := resolveShortStop(isReversalShort)
        pendingLong := false
    else if longSignal and shortSignal
        pendingLong := false
        pendingShort := false

longEntryNow = inSession and strategy.position_size == 0 and (entryOnNextBar ? (pendingLong[1] and canEnter) : pendingLong)
shortEntryNow = inSession and strategy.position_size == 0 and (entryOnNextBar ? (pendingShort[1] and canEnter) : pendingShort)

calcQty(entryPrice, stopPrice) =>
    riskPerUnit = math.abs(entryPrice - stopPrice)
    if not useRiskSizing
        fixedQty
    else if riskPerUnit <= syminfo.mintick
        fixedQty
    else
        riskCash = strategy.equity * riskPct / 100.0
        pointValue = nz(syminfo.pointvalue, 1.0)
        qty = riskCash / (riskPerUnit * pointValue)
        math.max(qty, 1.0)

if longEntryNow
    entry = entryOnNextBar ? open : close
    stop = entryOnNextBar ? pendingLongStop[1] : pendingLongStop
    risk = entry - stop
    if risk > syminfo.mintick
        target = entry + rewardRiskTarget * risk
        qty = calcQty(entry, stop)
        strategy.entry("ORB Long", strategy.long, qty=qty)
        strategy.exit("ORB Long Exit", "ORB Long", stop=stop, limit=target)
        tradedThisSession := true
        retestArmedLong := false
        retestArmedShort := false
    pendingLong := false

if shortEntryNow
    entry = entryOnNextBar ? open : close
    stop = entryOnNextBar ? pendingShortStop[1] : pendingShortStop
    risk = stop - entry
    if risk > syminfo.mintick
        target = entry - rewardRiskTarget * risk
        qty = calcQty(entry, stop)
        strategy.entry("ORB Short", strategy.short, qty=qty)
        strategy.exit("ORB Short Exit", "ORB Short", stop=stop, limit=target)
        tradedThisSession := true
        retestArmedLong := false
        retestArmedShort := false
    pendingShort := false

if closeAtSessionEnd and sessionEnded and strategy.position_size != 0
    strategy.close_all("Session End")
    pendingLong := false
    pendingShort := false

plot(orReady ? lockedOrHigh : na, "OR High", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(orReady ? lockedOrLow : na, "OR Low", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(orReady and retestLevel == "OR Midpoint" ? orMid : na, "OR Mid", color=color.new(color.yellow, 40), linewidth=1, style=plot.style_linebr)
plot(useTrendFilter ? trendEma : na, "Trend EMA", color=color.new(color.blue, 30))
plotshape(longEntryNow and not (shortEntryNow), "Long Entry", shape.triangleup, location.belowbar, color=color.green, size=size.small, text="L")
plotshape(shortEntryNow and not (longEntryNow), "Short Entry", shape.triangledown, location.abovebar, color=color.red, size=size.small, text="S")
plotshape(reversalLong and longSignal, "Reversal Long Setup", shape.circle, location.belowbar, color=color.new(color.green, 30), size=size.tiny, text="R")
plotshape(reversalShort and shortSignal, "Reversal Short Setup", shape.circle, location.abovebar, color=color.new(color.red, 30), size=size.tiny, text="R")
bgcolor(orReady and not orWidthOk ? color.new(color.red, 88) : inSession ? color.new(color.teal, 92) : na, title="Session / Skip")
