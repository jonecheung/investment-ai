//@version=5
indicator("<Strategy Name> <Long|Short> Screener", overlay=true)

// Pine Screener-compatible setup for medium-term daily charts (1-3 months).
// Trading Proposals Layer 2: Entry Price, Stop Price, Target Price, Reward Risk Ratio.
// TODO: strategy-specific inputs
rewardRiskTarget = input.float(2.5, "Reward Risk Target", minval=0.1, step=0.1)

// TODO: compute trend/momentum/breakdown conditions
setupCondition = false  // replace with real logic
risk = 0.0              // replace: abs distance entry to stop
setupActive = setupCondition and risk > 0
newSetup = setupActive and not setupActive[1]

entryPrice = setupActive ? close : na
stopPrice = setupActive ? close : na   // TODO: real stop anchor
targetPrice = setupActive ? close : na // TODO: entry +/- rewardRiskTarget * risk
rewardRiskRatio = setupActive ? rewardRiskTarget : na

// First ten plots = Pine Screener default columns. Keep this order.
plot(setupActive ? 1 : 0, "Setup Active", color=color.new(color.green, 0))
plot(newSetup ? 1 : 0, "New Setup", color=color.new(color.lime, 0))
plot(entryPrice, "Entry Price", color=color.new(color.blue, 0), linewidth=2)
plot(stopPrice, "Stop Price", color=color.new(color.red, 0), linewidth=2)
plot(targetPrice, "Target Price", color=color.new(color.green, 0), linewidth=2)
plot(rewardRiskRatio, "Reward Risk Ratio", color=color.new(color.purple, 0))
plot(0, "Diagnostic 1", color=color.new(color.gray, 0))   // TODO
plot(0, "Diagnostic 2", color=color.new(color.gray, 0))   // TODO
plot(0, "Diagnostic 3", color=color.new(color.gray, 0))     // TODO
plot(0, "Diagnostic 4", color=color.new(color.gray, 0))     // TODO

alertcondition(newSetup, "New Setup", "New setup generated.")
